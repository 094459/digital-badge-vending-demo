# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Admin Password Protection
ADMIN_PASSWORD=your-admin-password-here

# AWS Configuration
# AWS credentials are picked up from:
# 1. AWS CLI configuration (~/.aws/credentials)
# 2. IAM role (when running on EC2/ECS/Lambda)
# 3. Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# DO NOT store AWS credentials in this file

# Region where your ECS application is deployed
AWS_REGION=eu-west-1

# Region where Bedrock API calls are made (optional, defaults to AWS_REGION)
# Use this if you want to deploy in one region but call Bedrock in another
# Example: Deploy in eu-west-1 but call Bedrock in us-east-1
# BEDROCK_REGION=us-east-1

# Database
# Option 1: Full connection string (takes precedence)
DATABASE_URL=sqlite:///badges.db

# Option 2: Individual RDS Postgres connection vars (used if DATABASE_URL is not set)
# DB_HOST=your-rds-endpoint.eu-west-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=badges
# DB_USERNAME=postgres
# DB_PASSWORD=your-db-password

# Application
BASE_URL=http://127.0.0.1:5001

# S3 Storage (optional — uses local filesystem if not set)
# S3_BUCKET=digital-badge-assets
# S3_PREFIX=
